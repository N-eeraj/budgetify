<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>
      Reset Password
    </title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #0b0f0e;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <div
      style="
        width:100%;
        padding: 40px 16px;
        box-sizing: border-box;
      "
    >
      
      <div
        style="
          max-width: 520px;
          margin: 0 auto;
          background-color: #111615;
          border: 1px solid #3ecf8e26;
          border-radius: 14px;
          padding: 36px 32px;
          text-align: center;
          box-sizing: border-box;
        "
      >

        <div
          style="
            color: #3ecf8e;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 18px;
          "
        >
          Budgetify
        </div>

        <div
          style="
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 14px;
          "
        >
          Reset Your Password
        </div>

        <div
          style="
            color: #b7c2bd;
            font-size: 14px;
            line-height: 1.7;
            margin-bottom: 28px;
          "
        >
          We received a request to reset your Budgetify account password.
          Click the button below to choose a new password.
        </div>

        <div style="margin:32px 0;">
          <a
            href="{{resetPasswordUrl}}"
            target="_blank"
            style="
              display:inline-block;
              padding:14px 26px;
              background-color:#3ecf8e;
              color:#07110d;
              border-radius:10px;
              font-size:15px;
              font-weight:700;
              text-decoration:none;
            "
          >
            Reset Password
          </a>
        </div>

        <div
          style="
            color:#8a9490;
            font-size:13px;
            line-height:1.6;
            margin-top:18px;
            word-break:break-word;
          "
        >
          If the button above doesn’t work, copy and paste this link:
          <br /><br />
          <a
            href="{{resetPasswordUrl}}"
            target="_blank"
            style="
              color:#3ecf8e;
              text-decoration:none;
              word-break:break-all;
            "
          >
            {{resetPasswordUrl}}
          </a>
        </div>

        <div
          style="
          margin-top:22px;
          color:#8a9490;
          font-size:13px;
          line-height:1.6;
          "
        >
          This password reset link will expire shortly for security reasons.
          If you didn’t request a password reset, you can safely ignore this email.
        </div>
      </div>
    </div>
  </body>
</html>
